{
  "name": "rinka",
  "version": "0.0.1",
  "description": "Opt-in per-route Dynamic Worker (Worker Loader) delegation for Hono apps on Cloudflare Workers",
  "repository": "github:L4Ph/Rinka",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./proxies": {
      "types": "./dist/proxies.d.mts",
      "import": "./dist/proxies.mjs"
    },
    "./vite": {
      "types": "./dist/vite/plugin.d.mts",
      "import": "./dist/vite/plugin.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "prepublishOnly": "pnpm run build",
    "test": "vp test run",
    "test:watch": "vp test"
  },
  "dependencies": {
    "oxc-parser": "^0.127.0",
    "vite-plus": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^24.12.4",
    "hono": "^4.12.18",
    "typescript": "^5.9.0",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0"
}
